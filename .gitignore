# ------------------------------
# Logs and runtime artifacts
# ------------------------------
debug.log
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------
# Dependencies
# ------------------------------
node_modules/
**/node_modules/

# ------------------------------
# Build outputs and coverage
# ------------------------------
dist/
build/
coverage/
*.tsbuildinfo
vite.svg

# ------------------------------
# Environment and secrets
# ------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# ------------------------------
# Python / ML service artifacts
# ------------------------------
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.venv/
venv/
soko-insight/ml-service/venv/

# ------------------------------
# IDE and editor state
# ------------------------------
.cursor/
.vscode/
.idea/
*.swp
*.swo

# ------------------------------
# OS/system files
# ------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------
# Non-project personal documents
# ------------------------------
*.docx

# ------------------------------
# Repo scope guard
# Track only soko-insight and ignore files.
# ------------------------------
/*
!/soko-insight/
!/soko-insight/**
!/.gitignore
!/.cursorignore

# Re-ignore generated/sensitive content inside allowed project folder
/soko-insight/**/node_modules/
/soko-insight/**/dist/
/soko-insight/**/build/
/soko-insight/**/coverage/
/soko-insight/**/.env
/soko-insight/**/.env.*
!/soko-insight/**/.env.example
/soko-insight/**/venv/
/soko-insight/**/__pycache__/
/soko-insight/**/.vscode/
